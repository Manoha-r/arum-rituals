# ─── Aurum Ritual — Environment Variables ───────────────────────
# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to version control.

# API base URL (replace with your backend when ready)
VITE_API_BASE_URL=http://localhost:4000/api

# Shopify Storefront API (optional — for future Shopify integration)
# VITE_SHOPIFY_DOMAIN=your-store.myshopify.com
# VITE_SHOPIFY_STOREFRONT_TOKEN=your_public_token

# Analytics (optional)
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_META_PIXEL_ID=XXXXXXXXXX
